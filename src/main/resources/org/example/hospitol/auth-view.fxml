<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.hospitol.controller.AuthController"
           style="-fx-background-color: #f0f4f8;"
           prefWidth="420" prefHeight="560">

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  LOGIN CARD                                         -->
    <!-- ═══════════════════════════════════════════════════ -->
    <VBox fx:id="loginCard"
          maxWidth="360" maxHeight="440"
          alignment="CENTER" spacing="16"
          style="-fx-background-color: white; -fx-background-radius: 16;
                 -fx-padding: 40 36 40 36;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 20, 0, 0, 4);">

        <Label text="🏥 Hospital System"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a202c;"/>
        <Label text="Welcome back! Please sign in."
               style="-fx-font-size: 13px; -fx-text-fill: #718096;"/>

        <VBox spacing="6">
            <Label text="Username"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
            <TextField fx:id="loginUsername" promptText="Enter username"
                       style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0;
                              -fx-border-radius: 8; -fx-background-radius: 8;
                              -fx-padding: 10 12; -fx-pref-height: 40;"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Password"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
            <PasswordField fx:id="loginPassword" promptText="Enter password"
                           style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 10 12; -fx-pref-height: 40;"/>
        </VBox>

        <Label fx:id="loginError" text="" wrapText="true"
               style="-fx-text-fill: #e53e3e; -fx-font-size: 12px;"/>

        <Button text="Sign In" onAction="#handleLogin" maxWidth="Infinity"
                style="-fx-background-color: #3182ce; -fx-text-fill: white;
                       -fx-font-size: 14px; -fx-font-weight: bold;
                       -fx-background-radius: 8; -fx-padding: 12 0; -fx-cursor: hand;"/>

        <HBox alignment="CENTER" spacing="4">
            <Label text="Don't have an account?"
                   style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
            <Hyperlink text="Sign Up" onAction="#showSignup"
                       style="-fx-font-size: 12px; -fx-text-fill: #3182ce;
                              -fx-border-color: transparent; -fx-padding: 0;"/>
        </HBox>
    </VBox>

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  SIGNUP CARD                                        -->
    <!-- ═══════════════════════════════════════════════════ -->
    <VBox fx:id="signupCard"
          maxWidth="380" maxHeight="580"
          alignment="CENTER" spacing="14"
          visible="false" managed="false"
          style="-fx-background-color: white; -fx-background-radius: 16;
                 -fx-padding: 36 36 36 36;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 20, 0, 0, 4);">

        <Label text="🏥 Create Account"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a202c;"/>
        <Label text="Fill in your details to register."
               style="-fx-font-size: 13px; -fx-text-fill: #718096;"/>

        <!-- Email -->
        <VBox spacing="6">
            <Label text="Email"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
            <TextField fx:id="signupEmail" promptText="Enter email (e.g. name@mail.com)"
                       style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0;
                              -fx-border-radius: 8; -fx-background-radius: 8;
                              -fx-padding: 10 12; -fx-pref-height: 40;"/>
        </VBox>

        <!-- Username -->
        <VBox spacing="6">
            <Label text="Username"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
            <TextField fx:id="signupUsername" promptText="Enter username"
                       style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0;
                              -fx-border-radius: 8; -fx-background-radius: 8;
                              -fx-padding: 10 12; -fx-pref-height: 40;"/>
        </VBox>

        <!-- Password -->
        <VBox spacing="6">
            <Label text="Password"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
            <PasswordField fx:id="signupPassword" promptText="Enter password"
                           style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 10 12; -fx-pref-height: 40;"/>
            <Label text="Must have a letter, number and special character (!@#…)"
                   style="-fx-font-size: 11px; -fx-text-fill: #a0aec0;"/>
        </VBox>

        <!-- Role -->
        <VBox spacing="6">
            <Label text="Role"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
            <ComboBox fx:id="signupRole" promptText="Select role" maxWidth="Infinity"
                      style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0;
                             -fx-border-radius: 8; -fx-background-radius: 8; -fx-pref-height: 40;"/>
        </VBox>

        <Label fx:id="signupError" text="" wrapText="true"
               style="-fx-text-fill: #e53e3e; -fx-font-size: 12px;"/>
        <Label fx:id="signupSuccess" text="" wrapText="true"
               style="-fx-text-fill: #38a169; -fx-font-size: 12px; -fx-font-weight: bold;"/>

        <Button text="Create Account" onAction="#handleSignup" maxWidth="Infinity"
                style="-fx-background-color: #3182ce; -fx-text-fill: white;
                       -fx-font-size: 14px; -fx-font-weight: bold;
                       -fx-background-radius: 8; -fx-padding: 12 0; -fx-cursor: hand;"/>

        <HBox alignment="CENTER" spacing="4">
            <Label text="Already have an account?"
                   style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
            <Hyperlink text="Sign In" onAction="#showLogin"
                       style="-fx-font-size: 12px; -fx-text-fill: #3182ce;
                              -fx-border-color: transparent; -fx-padding: 0;"/>
        </HBox>
    </VBox>

</StackPane>
