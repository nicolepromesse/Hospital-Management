<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.hospitol.controller.PatientDashboardController"
      alignment="TOP_CENTER" spacing="16"
      style="-fx-padding: 24; -fx-background-color: #f0f4f8;">

    <!-- Title -->
    <Label text="🧑‍⚕️ Patient Dashboard"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a3a5c;"/>

    <Separator/>

    <!-- Booking Form -->
    <VBox spacing="10"
          style="-fx-background-color: white; -fx-background-radius: 12;
                 -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">

        <Label text="Book a New Appointment"
               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

        <HBox spacing="12" alignment="CENTER_LEFT">
            <VBox spacing="4">
                <Label text="Doctor" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                <!-- Changed from TextField to ComboBox -->
                <ComboBox fx:id="doctorComboBox"
                          promptText="Select Doctor"
                          prefWidth="180"
                          style="-fx-background-radius: 8; -fx-border-radius: 8;
                                 -fx-border-color: #bdc3c7; -fx-padding: 7 10 7 10;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Date (yyyy-MM-dd)" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                <TextField fx:id="dateField"
                           promptText="e.g. 2026-05-10"
                           prefWidth="150"
                           style="-fx-background-radius: 8; -fx-border-radius: 8;
                                  -fx-border-color: #bdc3c7; -fx-padding: 7 10 7 10;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Time (HH:mm)" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                <TextField fx:id="timeField"
                           promptText="e.g. 10:00"
                           prefWidth="120"
                           style="-fx-background-radius: 8; -fx-border-radius: 8;
                                  -fx-border-color: #bdc3c7; -fx-padding: 7 10 7 10;"/>
            </VBox>
            <VBox spacing="4">
                <Label text=" " style="-fx-font-size: 12px;"/>
                <Button text="📅 Book"
                        onAction="#bookAppointment"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 8;
                               -fx-padding: 8 20 8 20;"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- Action Buttons -->
    <HBox spacing="12" alignment="CENTER">
        <Button text="🗑 Cancel Selected"
                onAction="#cancelAppointment"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 18 8 18;"/>
        <Button text="🔄 Refresh"
                onAction="#refreshTable"
                style="-fx-background-color: #2980b9; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 18 8 18;"/>
        <Button text="📖 View Records"
                onAction="#viewRecords"
                style="-fx-background-color: #8e44ad; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 18 8 18;"/>
        <Button text="📋 View Appointments"
                onAction="#viewAppointments"
                style="-fx-background-color: #16a085; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 18 8 18;"/>
        <Button text="🚪 Logout"
                onAction="#logout"
                style="-fx-background-color: #34495e; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 18 8 18;"/>
    </HBox>

    <!-- Status message -->
    <Label fx:id="statusLabel" text=""
           style="-fx-font-size: 13px; -fx-font-weight: bold;"/>

    <!-- Appointments Table -->
    <TableView fx:id="appointmentTable"
               prefHeight="300" prefWidth="700"
               style="-fx-background-radius: 10;">
        <columns>
            <TableColumn fx:id="doctorColumn" text="Doctor"  prefWidth="160"/>
            <TableColumn fx:id="dateColumn"   text="Date"    prefWidth="130"/>
            <TableColumn fx:id="timeColumn"   text="Time"    prefWidth="100"/>
            <TableColumn fx:id="statusColumn" text="Status"  prefWidth="120"/>
        </columns>
        <placeholder>
            <Label text="No appointments yet. Book one above!" style="-fx-text-fill: #999;"/>
        </placeholder>
    </TableView>

</VBox>
